# Release Signing Keystore Configuration
# Copy this file to keystore.properties and fill in your actual values
# WARNING: keystore.properties and .jks files are INCLUDED IN .gitignore - NEVER COMMIT THEM TO GIT

# Path to your keystore file (relative to android/ directory or absolute path)
storeFile=../release-keystore.jks

# Keystore password
storePassword=your_keystore_password_here

# Key alias name
keyAlias=release

# Key password
keyPassword=your_key_password_here