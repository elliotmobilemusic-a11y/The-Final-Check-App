{
  "name": "kitchen-performance-tsx",
  "private": true,
  "version": "0.1.5",
  "description": "The Final Check desktop and web operating system for food-business consultancy delivery.",
  "author": "The Final Check",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:web": "vite --host 127.0.0.1",
    "dev:desktop": "concurrently -k \"npm:dev:web\" \"npm:desktop-shell\"",
    "desktop-shell": "wait-on tcp:5173 && electron electron/main.mjs",
    "typecheck": "tsc -b",
    "lint": "eslint \"src/**/*.{ts,tsx}\" vite.config.ts vitest.config.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "check": "npm run lint && npm run test:run && npm run build",
    "build": "tsc -b && vite build",
    "build:web": "tsc -b && vite build",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:android": "npm run cap:sync && npx cap run android",
    "android:open": "npx cap open android",
    "android:build:debug": "npm run cap:sync && cd android && ./gradlew assembleDebug",
    "android:build:release": "npm run cap:sync && cd android && ./gradlew assembleRelease",
    "android:build:bundle": "npm run cap:sync && cd android && ./gradlew bundleRelease",
    "android:publish:debug": "node scripts/publish-android-debug.mjs",
    "build:desktop": "npm run build:web && electron-builder --config electron-builder.config.mjs",
    "pack:desktop": "npm run build:web && electron-builder --dir --config electron-builder.config.mjs",
    "dist:mac": "npm run build:web && electron-builder --mac --config electron-builder.config.mjs",
    "dist:win": "npm run build:web && electron-builder --win --config electron-builder.config.mjs",
    "release:desktop": "npm run build:web && electron-builder --publish always --config electron-builder.config.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@supabase/supabase-js": "^2.103.0",
    "electron-updater": "^6.8.3",
    "pdfmake": "^0.3.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/pdfmake": "^0.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.3.5",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.4"
  }
}
